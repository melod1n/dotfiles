#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=dotfiles-common.sh
. "$SCRIPT_DIR/dotfiles-common.sh"
dotfiles_need_cmd chezmoi
dotfiles_need_cmd git

SOURCE_DIR="$(dotfiles_source_dir)"

cd "$SOURCE_DIR"

if git diff --quiet && git diff --cached --quiet; then
  dotfiles_notify normal "Dotfiles push skipped" "No changes to commit"
  exit 0
fi

COMMIT_MESSAGE="${1:-chore: update dotfiles}"

dotfiles_notify normal "Dotfiles push" "Staging, committing, and pushing changes..."

git add -A
git commit -m "$COMMIT_MESSAGE"
git push origin HEAD

dotfiles_notify success "Dotfiles push complete" "$COMMIT_MESSAGE"
