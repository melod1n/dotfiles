#!/usr/bin/env bash
set -euo pipefail

LOCK_DIR="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/dotfiles-update.lock.d"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=dotfiles-common.sh
. "$SCRIPT_DIR/dotfiles-common.sh"

dotfiles_need_cmd chezmoi
dotfiles_need_cmd git

if ! mkdir "$LOCK_DIR" 2>/dev/null; then
  dotfiles_notify normal "Dotfiles update skipped" "Another update is already running"
  exit 0
fi

cleanup() {
  rmdir "$LOCK_DIR" 2>/dev/null || true
}

trap cleanup EXIT INT TERM

SOURCE_DIR="$(dotfiles_source_dir)"

dotfiles_notify normal "Dotfiles update" "Pulling latest changes..."

cd "$SOURCE_DIR"

CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"

if ! git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
  dotfiles_fail "Current branch has no upstream: $CURRENT_BRANCH"
fi

if ! git diff --quiet || ! git diff --cached --quiet; then
  dotfiles_notify important "Dotfiles update" "Local changes detected; pull will use --autostash"
fi

git fetch --prune

BEFORE="$(git rev-parse HEAD)"

git pull --rebase --autostash

AFTER="$(git rev-parse HEAD)"

if [[ "$BEFORE" == "$AFTER" ]]; then
  PULL_STATUS="Already up to date"
else
  PULL_STATUS="Updated $BEFORE → $AFTER"
fi

dotfiles_notify normal "Dotfiles update" "Applying dotfiles: $PULL_STATUS"

chezmoi apply -v

dotfiles_notify success "Dotfiles update complete" "$PULL_STATUS"
