#!/usr/bin/env bash
set -euo pipefail

APP_NAME="dotfiles"
LOCK_FILE="${XDG_RUNTIME_DIR:-/tmp}/dotfiles-update.lock"

notify() {
  local urgency="$1"
  local title="$2"
  local body="${3:-}"

  if command -v notify-send >/dev/null 2>&1; then
    notify-send -a "$APP_NAME" -u "$urgency" "$title" "$body" -t 1500
  elif command -v hyprctl >/dev/null 2>&1 && [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
    local color="rgb(a6e3a1)"
    [[ "$urgency" == "critical" ]] && color="rgb(ff5555)"
    hyprctl notify 1 8000 "$color" "$title: ${body//$'\n'/; }" >/dev/null 2>&1 || true
  else
    printf '%s\n%s\n' "$title" "$body" >&2
  fi
}

fail() {
  notify critical "Dotfiles update failed" "$1"
  exit 1
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "Missing command: $1"
}

need_cmd chezmoi
need_cmd git

exec 9>"$LOCK_FILE"

if ! flock -n 9; then
  notify normal "Dotfiles update skipped" "Another update is already running"
  exit 0
fi

SOURCE_DIR="$(chezmoi source-path 2>/dev/null || true)"

[[ -n "$SOURCE_DIR" ]] || fail "Cannot detect chezmoi source path"
[[ -d "$SOURCE_DIR/.git" ]] || fail "Chezmoi source is not a git repository: $SOURCE_DIR"

notify normal "Updating dotfiles" "Pulling latest changes..."

cd "$SOURCE_DIR"

CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"

# Проверяем, есть ли upstream.
if ! git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
  fail "Current branch has no upstream: $CURRENT_BRANCH"
fi

# Показываем незакоммиченные изменения, но не ломаемся.
if ! git diff --quiet || ! git diff --cached --quiet; then
  notify normal "Dotfiles have local changes" "Pull will use --autostash"
fi

git fetch --prune

BEFORE="$(git rev-parse HEAD)"

git pull --rebase --autostash

AFTER="$(git rev-parse HEAD)"

if [[ "$BEFORE" == "$AFTER" ]]; then
  PULL_STATUS="Already up to date"
else
  PULL_STATUS="Updated $BEFORE → $AFTER"
fi

notify normal "Applying dotfiles" "$PULL_STATUS"

chezmoi apply -v

# Не фейлим весь update из-за theme-deps-check: это информационная проверка.
if command -v theme-deps-check >/dev/null 2>&1; then
  theme-deps-check || true
fi

notify normal "Dotfiles updated" "$PULL_STATUS"
