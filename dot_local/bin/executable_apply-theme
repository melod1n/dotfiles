#!/usr/bin/env bash
set -euo pipefail

DOT_NOTIFY="$HOME/.local/bin/dot-notify"
OS="$(uname -s 2>/dev/null || echo unknown)"

MODE="${1:-}"

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

is_hyprland_session() {
  [[ "${XDG_CURRENT_DESKTOP:-}" == *Hyprland* || "${XDG_SESSION_DESKTOP:-}" == *Hyprland* || -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]
}

case "$MODE" in
  dark|light)
    ;;
  *)
    echo "Usage: apply-theme dark|light" >&2
    exit 2
    ;;
esac

notify_theme() {
  if [[ "${DOT_THEME_NOTIFY:-1}" != "0" && -x "$DOT_NOTIFY" ]]; then
    "$DOT_NOTIFY" theme "Theme switched" "$MODE mode" || true
  fi
}

if [[ -x "$HOME/.local/bin/theme-deps-check" ]]; then
  "$HOME/.local/bin/theme-deps-check" || true
fi

mkdir -p "$HOME/.local/state"
echo "$MODE" > "$HOME/.local/state/theme-mode"

apply_linux() {
  local QT_SCHEME KDE_SCHEME DOLPHIN_SCHEME ICON_THEME GTK_THEME GTK_COLOR_SCHEME GTK_DARK
  local use_breeze_theme=0

  case "$MODE" in
    dark)
      QT_SCHEME="/usr/share/color-schemes/BreezeDark.colors"
      KDE_SCHEME="BreezeDark"
      DOLPHIN_SCHEME="Breeze Dark"
      ICON_THEME="breeze-dark"
      GTK_THEME="Breeze-Dark"
      GTK_COLOR_SCHEME="prefer-dark"
      GTK_DARK="1"
      if [[ -e "$QT_SCHEME" && -d /usr/share/icons/breeze-dark && -d /usr/share/themes/Breeze-Dark ]]; then
        use_breeze_theme=1
      fi
      ;;
    light)
      QT_SCHEME="/usr/share/color-schemes/BreezeLight.colors"
      KDE_SCHEME="BreezeLight"
      DOLPHIN_SCHEME="Breeze Light"
      ICON_THEME="breeze"
      GTK_THEME="Breeze"
      GTK_COLOR_SCHEME="prefer-light"
      GTK_DARK="0"
      if [[ -e "$QT_SCHEME" && -d /usr/share/icons/breeze && -d /usr/share/themes/Breeze ]]; then
        use_breeze_theme=1
      fi
      ;;
  esac

  if (( use_breeze_theme )) && is_hyprland_session && have_cmd hyprctl; then
    mkdir -p "$HOME/.config/hypr"

    cat > "$HOME/.config/hypr/hyprqt6engine.conf" <<EOF2
theme {
    color_scheme = $QT_SCHEME
    icon_theme = $ICON_THEME
    style = Breeze
    font = Noto Sans
    font_size = 10
    font_fixed = JetBrains Mono
    font_fixed_size = 10
}

misc {
    single_click_activate = false
    menus_have_icons = true
    shortcuts_for_context_menus = true
}
EOF2
  fi

  if (( use_breeze_theme )) && have_cmd kwriteconfig6; then
    kwriteconfig6 --file kdeglobals --group General --key ColorScheme "$KDE_SCHEME"
    kwriteconfig6 --file kdeglobals --group Icons --key Theme "$ICON_THEME"
    kwriteconfig6 --file kdeglobals --group KDE --key widgetStyle Breeze
    kwriteconfig6 --file dolphinrc --group UiSettings --key ColorScheme "$DOLPHIN_SCHEME"
  fi

  if have_cmd gsettings; then
    gsettings set org.gnome.desktop.interface color-scheme "$GTK_COLOR_SCHEME" || true
    if (( use_breeze_theme )); then
      gsettings set org.gnome.desktop.interface gtk-theme "$GTK_THEME" || true
      gsettings set org.gnome.desktop.interface icon-theme "$ICON_THEME" || true
    fi
  fi

  mkdir -p "$HOME/.config/gtk-3.0" "$HOME/.config/gtk-4.0"

  {
    printf '[Settings]\n'
    if (( use_breeze_theme )); then
      printf 'gtk-theme-name=%s\n' "$GTK_THEME"
      printf 'gtk-icon-theme-name=%s\n' "$ICON_THEME"
    fi
    printf 'gtk-application-prefer-dark-theme=%s\n' "$GTK_DARK"
  } > "$HOME/.config/gtk-3.0/settings.ini"

  {
    printf '[Settings]\n'
    if (( use_breeze_theme )); then
      printf 'gtk-theme-name=%s\n' "$GTK_THEME"
      printf 'gtk-icon-theme-name=%s\n' "$ICON_THEME"
    fi
    printf 'gtk-application-prefer-dark-theme=%s\n' "$GTK_DARK"
  } > "$HOME/.config/gtk-4.0/settings.ini"

  if (( use_breeze_theme )) && have_cmd dbus-send; then
    dbus-send --session --type=signal /KGlobalSettings org.kde.KGlobalSettings.notifyChange int32:0 int32:0 2>/dev/null || true
    dbus-send --session --type=signal /KGlobalSettings org.kde.KGlobalSettings.notifyChange int32:2 int32:0 2>/dev/null || true
  fi

  if (( use_breeze_theme )) && pgrep -x dolphin >/dev/null 2>&1; then
    pkill -x dolphin || true
  fi
}

apply_macos() {
  local apple_bool

  case "$MODE" in
    dark) apple_bool="true" ;;
    light) apple_bool="false" ;;
  esac

  if ! command -v osascript >/dev/null 2>&1; then
    if [[ -x "$DOT_NOTIFY" ]]; then
      "$DOT_NOTIFY" error "Theme switch failed" "osascript is missing"
    fi
    exit 1
  fi

  if ! osascript -e "tell application \"System Events\" to tell appearance preferences to set dark mode to $apple_bool" >/dev/null; then
    if [[ -x "$DOT_NOTIFY" ]]; then
      "$DOT_NOTIFY" error "Theme switch failed" "macOS denied System Events automation permission"
    fi
    exit 1
  fi
}

case "$OS" in
  Linux)
    apply_linux
    ;;
  Darwin)
    apply_macos
    ;;
  *)
    if [[ -x "$DOT_NOTIFY" ]]; then
      "$DOT_NOTIFY" error "Theme switch failed" "Unsupported OS: $OS"
    else
      echo "Unsupported OS: $OS" >&2
    fi
    exit 1
    ;;
esac

notify_theme
