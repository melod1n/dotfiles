#!/usr/bin/env bash
set -euo pipefail

CONFIG="$HOME/.config/dotfiles/notify.env"

if [[ -f "$CONFIG" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG"
fi

OS="$(uname -s 2>/dev/null || echo unknown)"

TYPE="${1:-normal}"
TITLE="${2:-Notification}"
BODY="${3:-}"

APP_NAME="${DOT_NOTIFY_APP_NAME:-dotfiles}"
BACKEND="${DOT_NOTIFY_BACKEND:-auto}"

case "$TYPE" in
  theme)
    URGENCY="low"
    TIMEOUT="${DOT_NOTIFY_THEME_MS:-1500}"
    HYPR_ICON=1
    HYPR_COLOR="rgb(89b4fa)"
    ;;
  success|ok)
    URGENCY="normal"
    TIMEOUT="${DOT_NOTIFY_SUCCESS_MS:-2500}"
    HYPR_ICON=1
    HYPR_COLOR="rgb(a6e3a1)"
    ;;
  normal|info)
    URGENCY="normal"
    TIMEOUT="${DOT_NOTIFY_NORMAL_MS:-4000}"
    HYPR_ICON=1
    HYPR_COLOR="rgb(cdd6f4)"
    ;;
  important|warning|warn)
    URGENCY="critical"
    TIMEOUT="${DOT_NOTIFY_IMPORTANT_MS:-0}"
    HYPR_ICON=2
    HYPR_COLOR="rgb(f9e2af)"
    ;;
  error|critical|fail|failed)
    URGENCY="critical"
    TIMEOUT="${DOT_NOTIFY_ERROR_MS:-0}"
    HYPR_ICON=3
    HYPR_COLOR="rgb(ff5555)"
    ;;
  *)
    URGENCY="normal"
    TIMEOUT="${DOT_NOTIFY_NORMAL_MS:-4000}"
    HYPR_ICON=1
    HYPR_COLOR="rgb(cdd6f4)"
    ;;
esac

if [[ "$TIMEOUT" == "0" ]]; then
  HYPR_TIMEOUT="${DOT_NOTIFY_HYPR_INFINITE_MS:-86400000}"
else
  HYPR_TIMEOUT="$TIMEOUT"
fi

as_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

notify_via_notify_send() {
  if [[ -n "$BODY" ]]; then
    notify-send -a "$APP_NAME" -u "$URGENCY" -t "$TIMEOUT" "$TITLE" "$BODY"
  else
    notify-send -a "$APP_NAME" -u "$URGENCY" -t "$TIMEOUT" "$TITLE"
  fi
}

notify_via_hyprctl() {
  local message="$TITLE"

  if [[ -n "$BODY" ]]; then
    message="$message: ${BODY//$'\n'/; }"
  fi

  hyprctl notify "$HYPR_ICON" "$HYPR_TIMEOUT" "$HYPR_COLOR" "$message" >/dev/null
}

notify_via_terminal_notifier() {
  local message="${BODY:-$TITLE}"

  terminal-notifier \
    -title "$TITLE" \
    -subtitle "$APP_NAME" \
    -message "$message" \
    -group "$APP_NAME.$TYPE" >/dev/null
}

notify_via_osascript_notification() {
  local title body subtitle

  title="$(as_escape "$TITLE")"
  body="$(as_escape "${BODY:-$TITLE}")"
  subtitle="$(as_escape "$APP_NAME")"

  osascript \
    -e "display notification \"$body\" with title \"$title\" subtitle \"$subtitle\"" >/dev/null
}

notify_via_osascript_alert() {
  local title body

  title="$(as_escape "$TITLE")"
  body="$(as_escape "${BODY:-$TITLE}")"

  # Запускаем в фоне, чтобы важный alert не блокировал скрипт.
  (
    osascript \
      -e "display alert \"$title\" message \"$body\" as critical" >/dev/null 2>&1
  ) &
}

notify_via_macos() {
  case "$TYPE" in
    important|warning|warn|error|critical|fail|failed)
      notify_via_osascript_alert
      ;;
    *)
      notify_via_osascript_notification
      ;;
  esac
}

notify_via_stderr() {
  if [[ -n "$BODY" ]]; then
    printf '[%s] %s\n%s\n' "$TYPE" "$TITLE" "$BODY" >&2
  else
    printf '[%s] %s\n' "$TYPE" "$TITLE" >&2
  fi
}

case "$BACKEND" in
  notify-send)
    if command -v notify-send >/dev/null 2>&1; then
      notify_via_notify_send || notify_via_stderr
    else
      notify_via_stderr
      exit 1
    fi
    ;;

  hyprctl)
    if command -v hyprctl >/dev/null 2>&1 && [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
      notify_via_hyprctl || notify_via_stderr
    else
      notify_via_stderr
      exit 1
    fi
    ;;

  terminal-notifier)
    if command -v terminal-notifier >/dev/null 2>&1; then
      notify_via_terminal_notifier || notify_via_stderr
    else
      notify_via_stderr
      exit 1
    fi
    ;;

  osascript)
    if command -v osascript >/dev/null 2>&1; then
      notify_via_macos || notify_via_stderr
    else
      notify_via_stderr
      exit 1
    fi
    ;;

  stderr)
    notify_via_stderr
    ;;

  auto|*)
    if [[ "$OS" == "Darwin" ]]; then
      if command -v terminal-notifier >/dev/null 2>&1; then
        notify_via_terminal_notifier && exit 0
      fi

      if command -v osascript >/dev/null 2>&1; then
        notify_via_macos && exit 0
      fi
    fi

    if command -v notify-send >/dev/null 2>&1; then
      notify_via_notify_send && exit 0
    fi

    if command -v hyprctl >/dev/null 2>&1 && [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
      notify_via_hyprctl && exit 0
    fi

    notify_via_stderr
    ;;
esac
