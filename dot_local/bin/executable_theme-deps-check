#!/usr/bin/env bash
set -u

DOT_NOTIFY="$HOME/.local/bin/dot-notify"
OS="$(uname -s 2>/dev/null || echo unknown)"

missing=()
optional=()

is_hyprland_session() {
  [[ "${XDG_CURRENT_DESKTOP:-}" == *Hyprland* || "${XDG_SESSION_DESKTOP:-}" == *Hyprland* || -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]
}

need_cmd() {
  local cmd="$1"
  local pkg="$2"

  if ! command -v "$cmd" >/dev/null 2>&1; then
    missing+=("$cmd  ← $pkg")
  fi
}

need_path() {
  local path="$1"
  local pkg="$2"

  if [[ ! -e "$path" ]]; then
    missing+=("$path  ← $pkg")
  fi
}

need_pacman_pkg() {
  local pkg="$1"
  local hint="$2"

  if command -v pacman >/dev/null 2>&1 && ! pacman -Qq "$pkg" >/dev/null 2>&1; then
    missing+=("$pkg  ← $hint")
  fi
}

case "$OS" in
  Linux)
    need_cmd darkman "pacman: darkman"
    need_cmd dbus-update-activation-environment "pacman: dbus"
    need_cmd dbus-send "pacman: dbus"
    need_cmd gsettings "pacman: glib2"
    need_cmd kwriteconfig6 "pacman: kconfig"
    need_cmd systemctl "pacman: systemd"

    need_path /usr/share/color-schemes/BreezeDark.colors "pacman: breeze"
    need_path /usr/share/color-schemes/BreezeLight.colors "pacman: breeze"
    need_path /usr/share/icons/breeze "pacman: breeze-icons"
    need_path /usr/share/icons/breeze-dark "pacman: breeze-icons"
    need_path /usr/share/themes/Breeze "pacman: breeze-gtk"
    need_path /usr/share/themes/Breeze-Dark "pacman: breeze-gtk"
    need_path /usr/lib/xdg-desktop-portal "pacman: xdg-desktop-portal"
    need_path /usr/lib/xdg-desktop-portal-gtk "pacman: xdg-desktop-portal-gtk"

    if is_hyprland_session; then
      need_cmd hyprctl "pacman: hyprland"
      need_path /usr/lib/xdg-desktop-portal-hyprland "pacman: xdg-desktop-portal-hyprland"
      need_pacman_pkg hyprqt6engine "AUR: hyprqt6engine"
    fi
    ;;

  Darwin)
    need_cmd osascript "built-in macOS tool"
    need_cmd defaults "built-in macOS tool"

    if ! command -v terminal-notifier >/dev/null 2>&1; then
      optional+=("terminal-notifier  ← optional: brew install terminal-notifier")
    fi
    ;;

  *)
    missing+=("Unsupported OS: $OS")
    ;;
esac

if ((${#missing[@]} > 0)); then
  case "$OS" in
    Linux)
      if command -v pacman >/dev/null 2>&1; then
        install_hint="Arch Linux:
sudo pacman -S --needed darkman libnotify dbus glib2 gsettings-desktop-schemas kconfig breeze breeze-icons breeze-gtk xdg-desktop-portal xdg-desktop-portal-gtk xdg-desktop-portal-hyprland

yay -S --needed hyprqt6engine"
      else
        install_hint="Install the missing components with your distro package manager."
      fi
      ;;
    Darwin)
      install_hint="macOS:
brew install terminal-notifier

Если отсутствуют osascript/defaults — что-то сильно сломано в системе."
      ;;
    *)
      install_hint="No install hint for OS: $OS"
      ;;
  esac

  body="Не хватает компонентов:

$(printf '• %s\n' "${missing[@]}")

$install_hint"

  if [[ -x "$DOT_NOTIFY" ]]; then
    "$DOT_NOTIFY" important "Theme setup incomplete" "$body" || true
  else
    printf '%s\n' "$body" >&2
  fi
fi

if [[ "${DOT_SHOW_OPTIONAL_DEPS:-0}" == "1" && ${#optional[@]} -gt 0 ]]; then
  body="Опциональные компоненты:

$(printf '• %s\n' "${optional[@]}")"

  if [[ -x "$DOT_NOTIFY" ]]; then
    "$DOT_NOTIFY" normal "Optional dependencies" "$body" || true
  else
    printf '%s\n' "$body" >&2
  fi
fi

exit 0
