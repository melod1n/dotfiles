#!/usr/bin/env bash
set -u

DOT_NOTIFY="$HOME/.local/bin/dot-notify"
OS="$(uname -s 2>/dev/null || echo unknown)"

missing=()
optional=()

is_hyprland_session() {
  [[ "${XDG_CURRENT_DESKTOP:-}" == *Hyprland* || "${XDG_SESSION_DESKTOP:-}" == *Hyprland* || -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]
}

need_cmd() {
  local cmd="$1"
  local pkg="$2"

  if ! command -v "$cmd" >/dev/null 2>&1; then
    missing+=("$cmd  ← $pkg")
  fi
}

need_path() {
  local path="$1"
  local pkg="$2"

  if [[ ! -e "$path" ]]; then
    missing+=("$path  ← $pkg")
  fi
}

case "$OS" in
  Linux)
    need_cmd darkman "your distro package manager"

    if is_hyprland_session; then
      need_cmd hyprctl "Hyprland session"
    fi
    ;;

  Darwin)
    need_cmd osascript "built-in macOS tool"
    need_cmd defaults "built-in macOS tool"

    if ! command -v terminal-notifier >/dev/null 2>&1; then
      optional+=("terminal-notifier  ← optional: brew install terminal-notifier")
    fi
    ;;

  *)
    missing+=("Unsupported OS: $OS")
    ;;
esac

if ((${#missing[@]} > 0)); then
  case "$OS" in
    Linux)
      if command -v pacman >/dev/null 2>&1; then
        if is_hyprland_session; then
          install_hint="Arch Linux:
sudo pacman -S --needed darkman hyprland"
        else
          install_hint="Arch Linux:
sudo pacman -S --needed darkman"
        fi
      else
        install_hint="Install the missing components with your distro package manager."
      fi
      ;;
    Darwin)
      install_hint="macOS:
brew install terminal-notifier

Если отсутствуют osascript/defaults — что-то сильно сломано в системе."
      ;;
    *)
      install_hint="No install hint for OS: $OS"
      ;;
  esac

  body="Не хватает компонентов:

$(printf '• %s\n' "${missing[@]}")

$install_hint"

  if [[ -x "$DOT_NOTIFY" ]]; then
    "$DOT_NOTIFY" important "Theme setup incomplete" "$body" || true
  else
    printf '%s\n' "$body" >&2
  fi
fi

if [[ "${DOT_SHOW_OPTIONAL_DEPS:-0}" == "1" && ${#optional[@]} -gt 0 ]]; then
  body="Опциональные компоненты:

$(printf '• %s\n' "${optional[@]}")"

  if [[ -x "$DOT_NOTIFY" ]]; then
    "$DOT_NOTIFY" normal "Optional dependencies" "$body" || true
  else
    printf '%s\n' "$body" >&2
  fi
fi

exit 0
