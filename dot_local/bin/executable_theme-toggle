#!/usr/bin/env bash
set -euo pipefail

if command -v theme-deps-check >/dev/null 2>&1; then
  theme-deps-check --quiet || true
fi

if ! command -v darkman >/dev/null 2>&1; then
  if command -v notify-send >/dev/null 2>&1; then
    notify-send -u critical -a dotfiles "darkman is missing" "Install: sudo pacman -S darkman"
  elif command -v hyprctl >/dev/null 2>&1; then
    hyprctl notify 3 8000 "rgb(ff5555)" "darkman is missing. Install: sudo pacman -S darkman" >/dev/null 2>&1 || true
  fi
  exit 1
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl --user start darkman.service >/dev/null 2>&1 || true
fi

darkman toggle