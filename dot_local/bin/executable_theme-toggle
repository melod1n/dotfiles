#!/usr/bin/env bash
set -euo pipefail

DOT_NOTIFY="$HOME/.local/bin/dot-notify"

if [[ -x "$HOME/.local/bin/theme-deps-check" ]]; then
  "$HOME/.local/bin/theme-deps-check" || true
fi

if ! command -v darkman >/dev/null 2>&1; then
  if [[ -x "$DOT_NOTIFY" ]]; then
    "$DOT_NOTIFY" error "darkman is missing" "Install: sudo pacman -S darkman" || true
  else
    echo "darkman is missing. Install: sudo pacman -S darkman" >&2
  fi

  exit 1
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl --user start darkman.service >/dev/null 2>&1 || true
fi

darkman toggle
