#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: dotfiles-check-deps [--cmd COMMAND]... [--pkg PACKAGE]...

Check required commands/packages and offer installation when supported.
EOF
}

warn() {
  printf '%s\n' "$*" >&2
}

have() {
  command -v "$1" >/dev/null 2>&1
}

os_name() {
  uname -s 2>/dev/null || printf unknown
}

detect_pm() {
  case "$(os_name)" in
    Darwin)
      have brew && printf brew
      ;;
    Linux)
      if have apt-get; then printf apt
      elif have pacman; then printf pacman
      elif have dnf; then printf dnf
      fi
      ;;
  esac
}

pkg_install_name() {
  case "$1" in
    git) printf git ;;
    chezmoi) printf chezmoi ;;
    jq) printf jq ;;
    rg|ripgrep) printf ripgrep ;;
    fd|fd-find) case "$(detect_pm)" in apt) printf fd-find ;; *) printf fd ;; esac ;;
    bat) printf bat ;;
    fzf) printf fzf ;;
    *) printf '%s' "$1" ;;
  esac
}

install_cmd() {
  local pm="$1" pkg="$2"
  case "$pm" in
    brew) brew install "$pkg" ;;
    apt) sudo apt-get update && sudo apt-get install -y "$pkg" ;;
    pacman) sudo pacman -S --needed --noconfirm "$pkg" ;;
    dnf) sudo dnf install -y "$pkg" ;;
    *) return 1 ;;
  esac
}

COMMANDS=()
PACKAGES=()

while (($#)); do
  case "$1" in
    --cmd)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      COMMANDS+=("$2")
      shift 2
      ;;
    --pkg)
      [[ $# -ge 2 ]] || { usage; exit 2; }
      PACKAGES+=("$2")
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      COMMANDS+=("$1")
      shift
      ;;
  esac
done

if ((${#COMMANDS[@]} + ${#PACKAGES[@]} == 0)); then
  usage
  exit 2
fi

pm="$(detect_pm || true)"

missing=()
for cmd in "${COMMANDS[@]}"; do
  if ! have "$cmd"; then
    missing+=("cmd:$cmd")
  fi
done
for pkg in "${PACKAGES[@]}"; do
  if ! have "$pkg"; then
    missing+=("pkg:$pkg")
  fi
done

if ((${#missing[@]} == 0)); then
  printf 'All dependencies are present.\n'
  exit 0
fi

if [[ -z "$pm" ]]; then
  printf 'Missing dependencies:\n'
  printf '  %s\n' "${missing[@]}"
  printf 'No supported package manager detected, so nothing will be installed.\n'
  exit 1
fi

for item in "${missing[@]}"; do
  kind="${item%%:*}"
  name="${item#*:}"
  install_name="$name"
  if [[ "$kind" == cmd ]]; then
    install_name="$(pkg_install_name "$name")"
  fi

  if have "$name"; then
    continue
  fi

  printf 'Missing %s: %s\n' "$kind" "$name"
  printf 'Install %s with %s? [y/N] ' "$install_name" "$pm" >&2
  read -r reply </dev/tty || reply=""
  case "$reply" in
    y|Y|yes|YES)
      if ! install_cmd "$pm" "$install_name"; then
        printf 'Could not install %s with %s.\n' "$install_name" "$pm" >&2
        exit 1
      fi
      ;;
    *)
      printf 'Skipped %s.\n' "$name" >&2
      ;;
  esac
done

printf 'Done.\n'
