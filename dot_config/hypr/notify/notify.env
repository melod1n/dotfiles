# Small notifications
export DOT_NOTIFY_THEME_MS=1500
export DOT_NOTIFY_SUCCESS_MS=2500
export DOT_NOTIFY_NORMAL_MS=4000

# 0 = infinite for notify-send-compatible daemons.
export DOT_NOTIFY_IMPORTANT_MS=0
export DOT_NOTIFY_ERROR_MS=0

# hyprctl notify has no real infinite timeout, so emulate it.
export DOT_NOTIFY_HYPR_INFINITE_MS=86400000

# auto | notify-send | hyprctl | stderr
export DOT_NOTIFY_BACKEND=auto

export DOT_NOTIFY_APP_NAME=dotfiles