{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "lead",
  "share": "manual",
  "snapshot": true,
  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": "ask",
    "external_directory": "ask",
    "todowrite": "allow",

    // Web & Network Access
    "webfetch": "allow",
    "websearch": "allow",

    // Agent Capabilities
    "task": "allow",
    "skill": "allow",

    // Search & Introspection
    "glob": "allow",
    "grep": "allow",
    "list": "allow",

    // Interaction & Safety
    "question": "allow",
    "doom_loop": "ask",
    "lsp": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true,
      "timeout": 10000
    },
    "exa": {
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp",
			"enabled": true
		},
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 10000
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {},
      "enabled": false,
      "timeout": 10000
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": false,
      "timeout": 30000
    }
  },
  "tools": {
    "context7_*": false,
    "gh_grep_*": false,
    "sentry_*": false,
    "playwright_*": false
  },
  "agent": {
    "external-researcher": {
      "tools": {
        "context7_*": true,
        "gh_grep_*": true
      }
    },
    "architect": {
      "tools": {
        "context7_*": true,
        "gh_grep_*": true
      }
    },
    "kotlin-android": {
      "tools": {
        "context7_*": true,
        "gh_grep_*": true
      }
    },
    "backend": {
      "tools": {
        "context7_*": true,
        "gh_grep_*": true
      }
    },
    "devops": {
      "tools": {
        "context7_*": true,
        "gh_grep_*": true
      }
    },
    "ui-tui": {
      "tools": {
        "context7_*": true,
        "gh_grep_*": true,
        "playwright_*": true
      }
    },
    "tester": {
      "tools": {
        "playwright_*": true
      }
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      ".gradle/**",
      "target/**",
      ".idea/**",
      ".kotlin/**",
      ".fleet/**",
      ".run/**"
    ]
  },
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 10000
  },
  "lsp": true,
  "instructions": [
    "./tools/philosophy.md"
  ],
  "plugin": [
    [
      "opencode-models-discovery",
      {
        "providers": {
          "include": [
            "llama.cpp"
          ]
        },
        "discovery": {
          "enabled": true,
          "ttl": 15000
        },
        "smartModelName": true
      }
    ],
    "@tarquinen/opencode-dcp@3.1.3",
    "@franlol/opencode-md-table-formatter@0.0.6",
    "@kirmad/askuserquestion"
  ],
  "disabled_providers": [],
  "provider": {
    "llama.cpp": {
      "name": "llama.cpp",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "{env:LLAMA_CPP_URL}",
        "modelsDiscovery": {
          "enabled": true,
          "endpoint": "/v1/models",
        }
      },
      "models": {}
    }
  }
}
