{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
set -u

if [[ -x "$HOME/.local/bin/theme-deps-check" ]]; then
  "$HOME/.local/bin/theme-deps-check" || true
fi

if command -v systemctl >/dev/null 2>&1 && command -v darkman >/dev/null 2>&1; then
  systemctl --user enable --now darkman.service >/dev/null 2>&1 || true
fi

if [[ -x "$HOME/.local/bin/apply-theme" ]]; then
  mode="$(cat "$HOME/.local/state/theme-mode" 2>/dev/null || echo dark)"
  DOT_THEME_NOTIFY=0 "$HOME/.local/bin/apply-theme" "$mode" || true
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl --user restart xdg-desktop-portal.service >/dev/null 2>&1 || true
fi
{{ else if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -u

if [[ -x "$HOME/.local/bin/theme-deps-check" ]]; then
  "$HOME/.local/bin/theme-deps-check" || true
fi

# На macOS не форсим тему при первом chezmoi apply.
# Применяем только уже сохранённое состояние.
if [[ -f "$HOME/.local/state/theme-mode" && -x "$HOME/.local/bin/apply-theme" ]]; then
  mode="$(cat "$HOME/.local/state/theme-mode" 2>/dev/null || true)"

  case "$mode" in
    dark|light)
      DOT_THEME_NOTIFY=0 "$HOME/.local/bin/apply-theme" "$mode" || true
      ;;
  esac
fi
{{ end -}}
