#!/usr/bin/env bash

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

shopt -s nullglob

shell_files=(
  dot_local/bin/*
  dot_config/hypr/notify/*.sh
)

if ((${#shell_files[@]} > 0)); then
  if command -v shellcheck >/dev/null 2>&1; then
    shellcheck --check-sourced "${shell_files[@]}"
  else
    printf 'warning: shellcheck is not installed; skipping shell checks\n' >&2
  fi
fi

gitleaks git \
  --redact \
  .