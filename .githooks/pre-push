#!/usr/bin/env bash
set -euo pipefail

echo "==> Running pre-push checks..."

if command -v gitleaks >/dev/null 2>&1; then
    echo "==> Scanning repository for secrets..."
    gitleaks detect --source . --verbose
else
    echo "WARN: gitleaks is not installed, skipping secret scan"
fi

echo "==> Done"
