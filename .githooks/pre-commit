#!/usr/bin/env bash

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

mapfile -d '' staged_files < <(
  git diff --cached --name-only --diff-filter=ACMR -z
)

shell_files=()

for file in "${staged_files[@]}"; do
  case "$file" in
    dot_local/bin/*|dot_config/hypr/notify/*.sh)
      shell_files+=("$file")
      ;;
  esac
done

if ((${#shell_files[@]} > 0)); then
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT

  git checkout-index --all --prefix="$tmp/"

  (
    cd "$tmp"
    shellcheck --check-sourced "${shell_files[@]}"
  )
fi

gitleaks git \
  --pre-commit \
  --staged \
  --redact \
  .